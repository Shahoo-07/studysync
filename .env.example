# Database
DATABASE_URL=postgresql://dev:devpass@localhost:5432/studysync
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your-super-secret-256-bit-key-change-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-256-bit-key-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Server
NODE_ENV=development
PORT=3001

# Client
VITE_API_URL=http://localhost:3001
VITE_SOCKET_URL=http://localhost:3001

# File Storage (optional - for local development)
FILE_STORAGE_PATH=/app/uploads

# AI (for Phase 6+)
GEMINI_API_KEY=
